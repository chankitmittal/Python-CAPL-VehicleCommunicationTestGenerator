  /* Function: programming_session
  Description: UDS Service 0x10 (Diagnostic Session Control) - Programming Session
  | sub_function (Byte 1)           |
  |---------------------------------|
  | 0x02: Programming Session           |
  */
  byte diag_request_byte[2] = {0x10, 0x02};
  DiagRequest_via_bytes(diag_request_obj, diag_request_byte);
}

