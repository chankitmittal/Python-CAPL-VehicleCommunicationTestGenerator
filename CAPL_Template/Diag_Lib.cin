/*@!Encoding:1252*/
includes
{
  #include "Preprocess_Flash_file.cin"
}

long UDS_Request(diagRequest * diagReq)
{
  /* Function: UDS_Request
  Description: MASTER BACKEND ENGINE. Handles CANoe transmission, timeout logic (TX/RX), and writes directly to the HTML test report.
  
  Execution Context (CRITICAL WARNING):
  STRICTLY FOR INTERNAL LIBRARY USE. DO NOT CALL THIS FUNCTION IN GENERATED TEST CASES!
  This function does NOT handle memory safety, array resizing, or byte assignment. 
  If you need to send a request, you MUST call a high-level wrapper (e.g., `DiagRequest_via_bytes_WithFixedLengthReturnType`, `tester_present`, or `readDtcInformationWithStatusMask`).
  */
  
  long ret_val = 0;
  
  // Send diag request
  diagSendRequest(diagReq);
  
  // Write requested service in the report
  testReportWriteDiagObject(diagReq);
  
  // wait for diagnostic request sent (5000ms timeout)
  if(1 == testWaitForDiagRequestSent(diagReq, 5000))
  {
    // wait for diagnostic response (10000ms timeout)
    switch(testWaitForDiagResponse(diagReq, 10000))
    {
      case 0:
        // Timeout: No response received from ECU
        testStepFail("Timeout", "ECU didn't respond within defined time.");
        break;
      case 1:
        // Response received
        testReportWriteDiagResponse(diagReq);
        
        // Check for Positive/Negative Response (-1 represents Positive Response in CANoe)
        if(diagGetLastResponseCode(diagReq) == -1)
        {
          teststep("Response Received", "Positive response received from requested diagnostic service.");
          ret_val = 1;
        }
        else
        {
          testStepFail("Response Received", "Negative Response Received.");
        }
        break;
      default:
        // Internal Error: Unknown Error
        testStepFail("Unexpected Error", "Internal/Setup Error: Verdict Unreliable.");
    }
  }
  else
  {
    // Unable to send the Diagnostic request
    testStepFail("Request Info", "Unable to send the diagnostic request within defined time.");
  }
  
  return ret_val;
}

void UDS_Response(diagRequest * diagReq, byte data_buffer[])
{
  /* Function: UDS_Response
  Description: Core utility to extract the raw hexadecimal response payload from the ECU after a successful UDS request.
  
  Dynamic Parameters:
  - diagReq: The global UDS diagnostic object (always pass `diag_request_obj`).
  - data_buffer: The array where the response bytes will be saved. 

  Execution Context:
  1. ARRAY SAFETY: ALWAYS declare a safe, oversized buffer before calling this function: `byte diag_response_byte[4096];`
  2. CHRONOLOGY: ONLY call this function AFTER successfully sending a request. It must be inside a success condition (e.g., `if (ret_status == 1)`).
  
  Note on Response Indexing:
  Once the data is extracted, `data_buffer[0]` will ALWAYS be the Response SID (Original SID + 0x40). 
  For example, if you sent Service 0x22, `data_buffer[0]` will be 0x62. The actual payload data starts at `data_buffer[1]` or later.
  */
  
  long buffer_size, i;
  buffer_size = DiagGetPrimitiveSize(diagReq);
  
  for(i=0; i < buffer_size; i++)
  {
    data_buffer[i] = DiagGetPrimitiveByte(diagReq, i);
  }
}

// Function can be used when service is requested via diag object is defined in the variables
void DiagRequest_via_object(diagRequest * diagReq)
{
  /* Function: DiagRequest_via_object
  Description: Sends a pre-configured UDS diagnostic object (linked from the CDD/PDX database) and logs a pass on positive response.
  
  Execution Context:
  1. USE CASE: ONLY use this function if the test specification explicitly provides the EXACT string name of a database object to instantiate. 
  2. RESTRICTION: Do NOT invent or guess CDD object names. If the user asks you to send raw hex bytes (e.g., 0x22 0xF1 0x90), you MUST use `DiagRequest_via_bytes_WithFixedLengthReturnType` instead.
  */
  
  if(1 == UDS_Request(diagReq))
  {
    testStepPass("Response Received", "Positive Response Received.");
  }
}

// Function can be used when service is requested via bytes
void DiagRequest_via_bytes(diagRequest * diagReq, byte request_arr[])
{
  /* Function: DiagRequest_via_bytes
  Description: Backend UDS execution wrapper for exact-size static arrays. Sends the payload and logs a pass on positive response.
  
  Execution Context (CRITICAL WARNING):
  DO NOT USE THIS FUNCTION FOR CUSTOM PAYLOADS!
  Because this function relies on array size inference, passing an oversized buffer will cause a fatal message length error. 
  If you are generating a custom UDS request in a test case, you MUST use `DiagRequest_via_bytes_WithFixedLengthReturnType` instead.
  */
  
  diagResize(diagReq, elCount(request_arr));
  diagSetPrimitiveData(diagReq, request_arr, elCount(request_arr));
  
  if(1 == UDS_Request(diagReq))
  {
    testStepPass("Response Received", "Positive Response Received");
  }
}

// Function can be used when service is requested via bytes with Fixed length
// Return status for further execution
int DiagRequest_via_bytes_WithFixedLengthReturnType(diagRequest * diagReq, byte request_arr[], int total_length)
{
  /* Function: DiagRequest_via_bytes_WithFixedLengthReturnType
  Description: Core UDS execution wrapper. Sends a raw array of hexadecimal bytes and returns the status (1 = Pass/Positive Response, 0 = Fail).
  
  Dynamic Parameters:
  - diagReq: The global UDS diagnostic object (always pass `diag_request_obj`).
  - request_arr: The array containing the exact UDS payload (SID + Sub-function + Data).
  - total_length: The exact number of bytes to send.

  Execution Context (CUSTOM PAYLOADS):
  If generating a custom UDS request, you MUST use this function with an auto-incrementing length variable to prevent CAPL array out-of-bounds errors.
  
  Example Usage:
  byte diag_request_byte[4096];
  int len = 0;
  diag_request_byte[len++] = 0xBA; // Custom SID
  diag_request_byte[len++] = 0x05; // Custom Sub-function
  int status = DiagRequest_via_bytes_WithFixedLengthReturnType(diag_request_obj, diag_request_byte, len);
  */
  
  int ret = 0;
  
  diagResize(diagReq, total_length);
  diagSetPrimitiveData(diagReq, request_arr, total_length);
  
  if(1 == UDS_Request(diagReq))
  {
    testStepPass("Response Received", "Positive Response Received");
    ret = 1;
  }
  
  return ret;
}

void default_session()
{
  /* Function: default_session
  Description: UDS Service 0x10 (Diagnostic Session Control) - Default Session
  | sub_function (Byte 1)           |
  |---------------------------------|
  | 0x01: Default Session           |
  */
  byte diag_request_byte[2] = {0x10, 0x01};
  DiagRequest_via_bytes(diag_request_obj, diag_request_byte);
}

